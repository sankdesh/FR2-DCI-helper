# DCI Decoder workspace .gitignore
#
# Source control here only tracks the helper scripts and small text
# fixtures. Large captures, archives, spec PDFs, and Office files
# are intentionally excluded - they belong on disk but not in git.

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
build/
dist/
!Try 2/dist/
Try 2/dist/*
!Try 2/dist/FR2_dci_helper.exe

# Logs / captures (large binary)
*.hdf
*.7z
*.pcap
*.pcap*
*.gz
*.zip

# 3GPP specification PDFs (very large)
ts_*.pdf

# Office docs (binary)
*.xlsx
*.xls
*.docx
!Try 2/3GPP_SPEC_TRACEABILITY.docx
*.doc

# Editor / OS noise
.vscode/
.idea/
.cursor/
Thumbs.db
.DS_Store

# Local scratch / tool output (not for git)
debug-*.log
out_*.txt
*_out.txt
missing_*.txt
spec_search*.txt
location.txt
verify_*.txt

# Generated Wireshark configs at repo root
/dci_0_1_fields_config
/dci_1_1_fields_config
